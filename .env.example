# מה-בלוז (Mabaluz) — environment example
# Copy to .env — the app runs fine with all values unset (safe mock defaults).
# Only VITE_* variables are exposed to the renderer.

# Support/contact phone shown on the contact + FAQ pages and in approval texts.
# Never hardcode this in source.
VITE_SUPPORT_PHONE=

# App environment label (dev / staging / prod). Informational only.
VITE_APP_ENV=dev

# ---- Future integrations (keep false in v1; toggles also exist in admin UI) ----
VITE_ENABLE_REAL_AUTH=false
VITE_ENABLE_MONGODB=false
VITE_ENABLE_OUTLOOK=false
VITE_ENABLE_AI_ANALYSIS=false

# ---- Future (main process only, not exposed to renderer) ----
# MONGODB_URI=
# OUTLOOK_TENANT_ID=
# OUTLOOK_CLIENT_ID=
# OUTLOOK_CLIENT_SECRET=
